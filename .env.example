# Trello (server-side only)
TRELLO_API_KEY=
TRELLO_TOKEN=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=

# Session encryption (generate: openssl rand -base64 32)
SESSION_SECRET=

# Admin password — staff portal (/admin) and customer portal master login (PIN field)
ADMIN_PASSWORD=

# Resend — email when customers send portal messages (https://resend.com)
RESEND_API_KEY=
